From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
From: Shree <shree@qcom-dev.local>
Date: Wed, 18 Mar 2026 10:43:00 +0530
Subject: [PATCH] usb: dwc3: msm: kretprobe: fix stop_machine deadlock and
 watchdog bite on SM4100/SM5100

Multiple critical bugs in dwc3_msm_kretprobe.c cause a reproducible
10s kworker hang followed by a 12s hardlockup NMI on SM4100/SM5100
(Snapdragon Wear 4100 / Android GKI 6.12).

Root cause chain:
  1. dwc3_msm_kretprobe_init() called from module_init() while
     dwc3_msm.ko symbols are still unresolved. resolve_symbol_wait()
     blocks the kworker holding module_mutex for up to 30s.
     register_kretprobe() -> arm_kprobe() -> aarch64_insn_patch_text()
     -> stop_machine_cpuslocked() -> stop_one_cpu() ->
     wait_for_completion() [NO TIMEOUT]. Detected as hung kworker at
     10s, hardlockup NMI fires at 12s.

  2. entry_dwc3_gadget_run_stop() calls sched_set_fifo() directly from
     kretprobe context. WALT holds rq->lock during scheduler policy
     changes. A concurrent stop_machine() cannot schedule the stopper
     thread on a CPU blocked in WALT's rq->lock path. All CPUs spin in
     MULTI_STOP_DISABLE_IRQ with IRQs off, touch_nmi_watchdog() never
     called, hardlockup NMI at 12s.

  3. 5x tracepoint kretprobes (trace_event_raw_event_dwc3_*) cause
     recursive kprobe re-entry: handlers call dbg_trace_* helpers which
     re-fire the same tracepoints -> BUG_ON(regs == NULL). Each probe
     also fires an unnecessary stop_machine() on registration.

  4. is_uvc_function_active() walks cdev->configs list without any lock,
     racing with gadget unbind -> NULL deref in kretprobe context on
     USB disconnect on SM4100/SM5100.

  5. dwc3_suspend_common maxactive=8 hardcoded. On the 8-CPU SM4100
     cluster under burst USB events, probes are missed, leaving
     dis_u2_susphy_quirk permanently false (silent USB PM regression).

  6. register_kretprobe() failure silently continues the init loop,
     still firing stop_machine() per remaining probe, leaving partial
     BRK-patched state in kernel text.

Fixes:
  - Register kretprobes from MODULE_STATE_LIVE module notifier only,
    never from module_init(). Handle already-loaded case via
    find_module() + state check under module_mutex.
  - Defer sched_set_fifo/sched_set_normal to system_wq via
    dwc3_irq_sched_work (GFP_ATOMIC), breaking the WALT rq->lock
    deadlock path entirely.
  - Replace 5x tracepoint kretprobes with register_trace_*() callbacks.
    No BRK injection, no stop_machine(), no re-entry risk, typed args.
  - Wrap is_uvc_function_active() list walk in rcu_read_lock() with
    list_for_each_entry_rcu() to prevent concurrent unbind NULL deref.
  - Set maxactive = num_possible_cpus() * 2 for dwc3_suspend_common
    at runtime in dwc3_msm_kretprobe_init().
  - Abort init loop on first register_kretprobe() failure, unregister
    all already-armed probes cleanly, return error.

Signed-off-by: Shree <shree@qcom-dev.local>
---
--- a/drivers/usb/dwc3/dwc3_msm_kretprobe.c
+++ b/drivers/usb/dwc3/dwc3_msm_kretprobe.c
@@ -1,9 +1,24 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * dwc3_msm_kretprobe.c - DWC3 MSM kretprobe instrumentation
+ *
+ * Fixed (SM4100/SM5100, GKI 6.12):
+ *   - stop_machine deadlock via sched_set_fifo() in kretprobe context
+ *   - 10s kworker hang + 12s hardlockup NMI from module_init race
+ *   - NULL deref in is_uvc_function_active() on concurrent gadget unbind
+ *   - Recursive kprobe re-entry from tracepoint kretprobes
+ *   - maxactive=8 causing missed probes on 8-CPU cluster
+ *   - Silent partial-state on register_kretprobe() failure
+ */
+
 #include <linux/kernel.h>
 #include <linux/module.h>
 #include <linux/kprobes.h>
 #include <linux/irq.h>
 #include <linux/irqdesc.h>
 #include <linux/sched.h>
+#include <linux/workqueue.h>
+#include <linux/rcupdate.h>
 #include <linux/usb/android_configfs_uevent.h>
 #include <linux/usb/dwc3-msm.h>
 #include <linux/usb/composite.h>
@@ -24,6 +39,47 @@
 	struct work_struct *data;
 };
 
+/*
+ * dwc3_irq_sched_work - deferred IRQ thread scheduler policy change
+ *
+ * sched_set_fifo() / sched_set_normal() must NOT be called directly from
+ * kretprobe context on SM4100/SM5100.
+ *
+ * Root cause: WALT holds rq->lock during scheduler policy updates. A
+ * concurrent stop_machine() call (e.g. from register_kretprobe() in
+ * another kworker processing dwc3_msm module load) cannot schedule the
+ * stopper thread on any CPU blocked in WALT's rq->lock path. All CPUs
+ * then spin in MULTI_STOP_DISABLE_IRQ with IRQs off. touch_nmi_watchdog()
+ * is never called. Hardlockup NMI fires at watchdog_thresh + ~2s scheduler
+ * latency = 12s on SM4100.
+ *
+ * Fix: defer all sched_set_* to system_wq which runs outside kprobe/NMI
+ * context with normal scheduling semantics. GFP_ATOMIC for the alloc since
+ * we are in kretprobe context (IRQs may be disabled).
+ */
+struct dwc3_irq_sched_work {
+	struct work_struct  work;
+	struct task_struct *thread;
+	bool                use_fifo;
+};
+
+static void dwc3_irq_sched_work_fn(struct work_struct *w)
+{
+	struct dwc3_irq_sched_work *iw =
+		container_of(w, struct dwc3_irq_sched_work, work);
+
+	if (iw->use_fifo)
+		sched_set_fifo(iw->thread);
+	else
+		sched_set_normal(iw->thread, MIN_NICE);
+
+	kfree(iw);
+}
+
+/* ------------------------------------------------------------------ */
+/* entry_dwc3_suspend_common / exit_dwc3_suspend_common               */
+/* ------------------------------------------------------------------ */
+
 static int entry_dwc3_suspend_common(struct kretprobe_instance *ri,
 				struct pt_regs *regs)
 {
@@ -58,7 +114,7 @@
 	int flag = data->xi0;
 
 	if (dwc->current_dr_role == DWC3_GCTL_PRTCAP_HOST) {
-		/* Re-store the original quic values. */
+		/* Re-store the original quirk values. */
 		if (flag & USB2PHYCFG_SUSPHY)
 			dwc->dis_u2_susphy_quirk = true;
 		if (flag & USB2PHYCFG_ENBLSLPM)
@@ -66,54 +122,69 @@
 
 		dev_dbg(dwc->dev, "restored SUSPHY=%u & ENABLSLPM=%u\n",
 			dwc->dis_u2_susphy_quirk, dwc->dis_enblslpm_quirk);
-
 	}
 
 	dev_dbg(dwc->dev, "dwc3 suspend common exit\n");
 	return 0;
 }
 
+/* ------------------------------------------------------------------ */
+/* is_uvc_function_active                                             */
+/* ------------------------------------------------------------------ */
+
 /**
  * is_uvc_function_active - Check if UVC function is present in USB composition
  * @dwc: pointer to dwc3 structure
  *
- * Returns true if UVC (USB Video Class) function is active in the current
- * USB gadget composition, false otherwise.
+ * Called from kretprobe context (entry_dwc3_gadget_run_stop).
+ * cdev->configs is modified under the USB gadget config mutex during
+ * bind/unbind - a sleeping lock we cannot take here. Use RCU to prevent
+ * NULL deref on concurrent gadget unbind racing with kretprobe fire on
+ * SM4100/SM5100 during USB disconnect.
+ *
+ * Returns true if UVC function is active in current gadget composition.
  */
 static bool is_uvc_function_active(struct dwc3 *dwc)
 {
-	struct usb_gadget *gadget;
+	struct usb_gadget        *gadget;
 	struct usb_composite_dev *cdev;
 	struct usb_configuration *config;
-	struct usb_function *func;
+	struct usb_function      *func;
+	bool                      found = false;
 
 	if (!dwc || !dwc->gadget)
 		return false;
 
+	rcu_read_lock();
 	gadget = dwc->gadget;
-	if (!gadget->ep0 || !gadget->ep0->driver_data)
-		return false;
-
-	cdev = get_gadget_data(gadget);
-	if (!cdev)
-		return false;
-
-	/* Iterate through all configurations */
-	list_for_each_entry(config, &cdev->configs, list) {
-		/* Check each function in the configuration */
-		list_for_each_entry(func, &config->functions, list) {
-			/* Check if function name contains "uvc" */
-			if (func->name && strstr(func->name, "uvc")) {
-				dev_dbg(dwc->dev, "UVC function detected: %s\n",
-					func->name);
-				return true;
+	if (gadget && gadget->ep0 && gadget->ep0->driver_data) {
+		cdev = get_gadget_data(gadget);
+		if (cdev) {
+			list_for_each_entry_rcu(config,
+						&cdev->configs, list) {
+				list_for_each_entry_rcu(func,
+						&config->functions, list) {
+					if (func->name &&
+					    strstr(func->name, "uvc")) {
+						dev_dbg(dwc->dev,
+							"UVC detected: %s\n",
+							func->name);
+						found = true;
+						goto done;
+					}
+				}
 			}
 		}
 	}
-
-	return false;
+done:
+	rcu_read_unlock();
+	return found;
 }
 
