+/**
+ * stopper_deadlock_dump() - orchestrate dual all-CPU dump then panic
+ * @cpu:       dump owner CPU index
+ * @msdata:    shared multi_stop_data
+ * @elapsed_j: jiffies elapsed since spin entry (used for timing messages)
+ * @t_detect:  ktime at which time_after() first fired (T=8s)
+ *
+ * Sections and timeline (all times relative to t_detect):
+ *   Sec1: outer stopper fn + caller (root cause identification)
+ *   Sec2: multi_stop_data state snapshot
+ *   Sec3: CPU masks (cpu_dying_mask non-zero -> hotplug variant)
+ *   Sec4: owner CPU detailed stopper state
+ *   Sec5: wait for FIRST dump_stack() from all CPUs (->T=8.8s)
+ *   Sec6: print per-CPU snapshots collected in Phase 1
+ *   +800ms:  set stopper_second_dump_trigger; SECOND dump on all CPUs
+ *   Sec7: wait for SECOND dump_stack() from all CPUs (->T=9.6s)
+ *   +2000ms: panic()
+ *
+ * noinline: preserves "stopper_deadlock_dump" in ramdump call stack.
+ */
+static noinline void stopper_deadlock_dump(unsigned int cpu,
+					   struct multi_stop_data *msdata,
+					   unsigned long elapsed_j,
+					   ktime_t t_detect)
+{
+	struct cpu_stopper *st     = this_cpu_ptr(&cpu_stopper);
+	ktime_t t_dump1_limit      = ktime_add_ms(t_detect, STOPPER_DUMP1_WINDOW_MS);
+	ktime_t t_dump2_trigger    = ktime_add_ms(t_detect, STOPPER_DUMP2_TRIGGER_MS);
+	ktime_t t_dump2_limit      = ktime_add_ms(t_detect, STOPPER_DUMP2_WINDOW_MS);
+	ktime_t t_panic            = ktime_add_ms(t_detect, STOPPER_PANIC_WINDOW_MS);
+
+	pr_emerg("\n");
+	pr_emerg("=====================================================\n");
+	pr_emerg("STOPPER DEADLOCK: migration/%u stuck ~%ums\n"
+		 "DUAL DUMP: FIRST=T+0ms  SECOND=T+800ms  PANIC=T+2000ms\n"
+		 "WDT bark: ~T+3000ms (T=deadlock+11s)\n",
+		 cpu, jiffies_to_msecs(elapsed_j));
+	pr_emerg("Patterns: A=LB re-entrancy  B=concurrent exhaustion"
+		 "  G=WALT init race\n");
+	pr_emerg("=====================================================\n");
+
+	/* Sec1: root cause -- which callback triggered the deadlock */
+	pr_emerg("=== Sec1: CPU%u outer stopper (root cause) ===\n", cpu);
+	pr_emerg("  outer fn    : %pS\n", READ_ONCE(st->fn));
+	pr_emerg("  outer caller: %pS\n",
+		 (void *)READ_ONCE((unsigned long)st->caller));
+
+	/* Sec2: state machine snapshot */
+	stopper_dump_msdata(msdata, cpu);
+
+	/* Sec3: CPU masks (cpu_dying_mask != 0 means hotplug-induced variant) */
+	pr_emerg("=== Sec3: CPU masks ===\n");
+	pr_emerg("  cpu_online_mask : %*pbl\n",
+		 cpumask_pr_args(cpu_online_mask));
+	pr_emerg("  cpu_active_mask : %*pbl\n",
+		 cpumask_pr_args(cpu_active_mask));
+	pr_emerg("  cpu_dying_mask  : %*pbl  (non-zero = hotplug variant)\n",
+		 cpumask_pr_args(cpu_dying_mask));
+
+	/* Sec4: detailed stopper state of the dump-owner CPU */
+	pr_emerg("=== Sec4: CPU%u stopper state (detailed) ===\n", cpu);
+	stopper_dump_one_cpu(cpu);
+
+	/*
+	 * Sec5: block until every online PREPARE CPU has completed its
+	 * FIRST dump_stack() (stopper_first_dump_done == 1), or until
+	 * the t_dump1_limit deadline.  DISABLE_IRQ CPUs are logged as
+	 * "see ramdump" and skipped.
+	 */
+	stopper_wait_for_first_dumps(cpu, t_dump1_limit);
+
+	/* Sec6: per-CPU snapshots written by Phase 1 (all CPUs at T=8s) */
+	stopper_print_other_snapshots(cpu);
+
+	/*
+	 * === SECOND DUMP (T=~8.8s) ===
+	 *
+	 * Spin until t_dump2_trigger (t_detect + DUMP2_TRIGGER_MS = +800ms).
+	 * This equals DUMP1_WINDOW_MS so the second dump fires immediately
+	 * after Sec5 completes.
+	 *
+	 * smp_wmb() before atomic_set() ensures all Sec1-6 printk output
+	 * is ordered before non-owner CPUs see the trigger flag.
+	 */
+	while (ktime_before(ktime_get(), t_dump2_trigger))
+		cpu_relax();
+
+	pr_emerg("\n");
+	pr_emerg("=====================================================\n");
+	pr_emerg("SECOND DUMP: pre-panic all-CPU dump_stack\n");
+	pr_emerg("  First  dump @ T=8.0s -- deadlock onset\n");
+	pr_emerg("  Second dump @ T=8.8s -- pre-panic confirmation\n");
+	pr_emerg("  No progress = confirmed livelock (not transient delay)\n");
+	pr_emerg("=====================================================\n");

+	/* Signal non-owner PREPARE CPUs to perform second dump_stack() */
+	smp_wmb();
+	atomic_set(&stopper_second_dump_trigger, 1);
+
+	/* Owner SECOND dump_stack() -- mirrors non-owner Phase 3 */
+	pr_emerg("CPU%u SECOND dump_stack (pre-panic ~+%lldms):\n",
+		 cpu, ktime_to_ms(ktime_sub(ktime_get(), t_detect)));
+	dump_stack();
+	atomic_set(this_cpu_ptr(&stopper_second_dump_done), 1);
+
+	/*
+	 * Sec7: block until every online PREPARE CPU has completed its
+	 * SECOND dump_stack() (stopper_second_dump_done == 1), or until
+	 * the t_dump2_limit deadline.  DISABLE_IRQ CPUs timed out already.
+	 */
+	stopper_wait_for_second_dumps(cpu, t_dump2_limit);
+
+	pr_emerg("=====================================================\n");
+	pr_emerg("Both dumps complete (+%lldms). panic() in ~%lldms.\n",
+		 ktime_to_ms(ktime_sub(ktime_get(), t_detect)),
+		 ktime_to_ms(ktime_sub(t_panic, ktime_get())));
+	pr_emerg("DISABLE_IRQ CPU stacks: see ramdump.\n");
+	pr_emerg("=====================================================\n");
+
+	/* Spin until panic deadline (allows final kmsg flush to UART/pstore) */
+	while (ktime_before(ktime_get(), t_panic))
+		cpu_relax();
+
+	panic("migration/%u: stuck in multi_cpu_stop ~%ums |"
+	      " state=%s thread_ack=%d stop_fn=%pS |"
+	      " stop_machine deadlock | dual dump in kmsg | see ramdump\n",
+	      cpu,
+	      jiffies_to_msecs(elapsed_j),
+	      stopper_state_names[
+		  min_t(unsigned int,
+			(unsigned int)READ_ONCE(msdata->state),
+			MULTI_STOP_EXIT)],
+	      atomic_read(&msdata->thread_ack),
+	      READ_ONCE(msdata->fn));
+}
