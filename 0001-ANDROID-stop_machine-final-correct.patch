---
 kernel/stop_machine.c | 438 ++++++++++++++++++++++++++++++++++++++++--
 1 file changed, 426 insertions(+), 12 deletions(-)

diff --git a/kernel/stop_machine.c b/kernel/stop_machine.c
index 5d2d056..final 100644
--- a/kernel/stop_machine.c
+++ b/kernel/stop_machine.c
@@ -10,9 +10,16 @@
 #include <linux/compiler.h>
 #include <linux/completion.h>
 #include <linux/cpu.h>
+#include <linux/cpumask.h>
+#include <linux/debugfs.h>
+#include <linux/delay.h>
+#include <linux/err.h>
+#include <linux/jiffies.h>
 #include <linux/init.h>
 #include <linux/kthread.h>
 #include <linux/export.h>
+#include <linux/moduleparam.h>
+#include <linux/uaccess.h>
 #include <linux/percpu.h>
+#include <linux/sched/debug.h>
 #include <linux/sched.h>
 #include <linux/stop_machine.h>
 #include <linux/interrupt.h>
@@ -25,6 +32,30 @@
 #include <linux/nmi.h>
 #include <linux/sched/wake_q.h>
 
+/*
+ * stopper_timeout_sec — runtime-configurable deadlock panic threshold.
+ *
+ * Default = 3 s (production).  Reduce to 1 for faster test iterations.
+ *   Boot   : stopper_timeout_sec=1
+ *   Runtime: echo 1 > /sys/module/stop_machine/parameters/stopper_timeout_sec
+ *
+ * module_param() on a built-in .c is valid: the parameter is accessible
+ * via kernel command line and /sys/module/stop_machine/parameters/.
+ */
+static unsigned int stopper_timeout_sec = 3;
+module_param(stopper_timeout_sec, uint, 0644);
+MODULE_PARM_DESC(stopper_timeout_sec,
+		 "Deadlock panic threshold in seconds (default=3, test with 1)");
+
+/*
+ * STOPPER_TIMEOUT_JIFFIES — jiffies-based panic threshold.
+ * jiffies freeze when IRQs are disabled (DISABLE_IRQ/RUN states) so the
+ * timeout auto-suppresses during normal IRQ-off stop_machine operation —
+ * no explicit state check needed.  See commit message for full rationale.
+ * Default: stopper_timeout_sec(3) * HZ(250) = 750 jiffies = 3000 ms.
+ */
+#define STOPPER_TIMEOUT_JIFFIES		(stopper_timeout_sec * HZ)
+
+/* Compile-time guard: catches misconfigured HZ before runtime. */
+static_assert(HZ > 0, "HZ must be > 0");
+
 /*
  * Structure to determine completion condition and record errors. May
  * be shared by works on different cpus.
@@ -167,6 +208,305 @@ enum multi_stop_state {
 	MULTI_STOP_EXIT,
 };
 
+/*
+ * stopper_state_names[] — human-readable names for enum multi_stop_state.
+ * Defined here (after the enum) so designated initialiser constants resolve.
+ *
+ * The static_assert below keeps names[] in sync if new states are added:
+ * a missing entry would make stopper_state_names[new_state] == NULL,
+ * which causes a %s NULL-pointer deref in pr_emerg() — silent UB.
+ */
+static const char * const stopper_state_names[] = {
+	[MULTI_STOP_NONE]        = "NONE",
+	[MULTI_STOP_PREPARE]     = "PREPARE",
+	[MULTI_STOP_DISABLE_IRQ] = "DISABLE_IRQ",
+	[MULTI_STOP_RUN]         = "RUN",
+	[MULTI_STOP_EXIT]        = "EXIT",
+};
+static_assert(ARRAY_SIZE(stopper_state_names) == MULTI_STOP_EXIT + 1,
+	      "stopper_state_names[] out of sync with enum multi_stop_state");
+
+/* -----------------------------------------------------------------------
+ * Stopper deadlock diagnostic helpers.
+ * stopper_dump_one_cpu / stopper_dump_msdata / stopper_deadlock_dump are
+ * noinline and are only ever called from the panic / test path.
+ * ----------------------------------------------------------------------- */
+
+/**
+ * stopper_dump_one_cpu() - print per-cpu stopper state to dmesg
+ * @cpu: target CPU (unsigned int matches smp_processor_id() return type)
+ *
+ * Lockless read of cpu_stopper — intentional on the panic path.
+ * A best-effort snapshot is the right trade-off over missing the dump.
+ */
+static noinline void stopper_dump_one_cpu(unsigned int cpu)
+{
+	struct cpu_stopper *st = per_cpu_ptr(&cpu_stopper, cpu);
+	struct cpu_stop_work *w;
+	int n = 0;
+
+	pr_emerg("  [CPU%u stopper] task=%-16s enabled=%d\n",
+		 cpu,
+		 st->thread ? st->thread->comm : "(null)",
+		 st->enabled);
+	pr_emerg("                 fn=%pS  caller=%pS\n",
+		 st->fn, (void *)st->caller);
+
+	/* Walk pending work list — lockless, best-effort. */
+	list_for_each_entry(w, &st->works, list) {
+		pr_emerg("    pending[%d]: fn=%pS  caller=%pS\n",
+			 n++, w->fn, (void *)w->caller);
+		if (n >= 8) {
+			pr_emerg("    ... (truncated at 8 entries)\n");
+			break;
+		}
+	}
+	if (!n)
+		pr_emerg("    pending works: (none)\n");
+}
+
+/**
+ * stopper_dump_msdata() - print multi_stop_data fields to dmesg
+ * @msdata:    shared state machine data (may be synthetic for test)
+ * @stuck_cpu: CPU that detected the timeout
+ */
+static noinline void stopper_dump_msdata(const struct multi_stop_data *msdata,
+					 unsigned int stuck_cpu)
+{
+	int state = READ_ONCE(msdata->state);
+	const char *sname;
+
+	sname = ((unsigned int)state < ARRAY_SIZE(stopper_state_names) &&
+		 stopper_state_names[state])
+		? stopper_state_names[state] : "UNKNOWN";
+
+	pr_emerg("=== multi_stop_data (CPU%u) ===\n", stuck_cpu);
+	pr_emerg("  state       : %d (%s)\n", state, sname);
+	pr_emerg("  num_threads : %u\n", msdata->num_threads);
+	pr_emerg("  thread_ack  : %d  <- CPUs NOT yet acked\n",
+		 atomic_read(&msdata->thread_ack));
+	pr_emerg("  inner fn    : %pS\n", msdata->fn);
+	pr_emerg("  active_cpus : %*pbl\n",
+		 cpumask_pr_args(msdata->active_cpus
+				 ? msdata->active_cpus : cpu_online_mask));
+}
+
+/**
+ * stopper_deadlock_dump() - emit 7-section diagnostic dump before panic()
+ * @cpu:       detecting CPU id (unsigned int)
+ * @msdata:    shared multi_stop_data for this stop operation
+ * @elapsed_j: jiffies elapsed since spin entry (display only)
+ *
+ * noinline so migration/N appears cleanly at the top of the call stack.
+ * Returns to caller which must call panic().
+ */
+static noinline void stopper_deadlock_dump(unsigned int cpu,
+					   struct multi_stop_data *msdata,
+					   unsigned long elapsed_j)
+{
+	struct cpu_stopper *st = this_cpu_ptr(&cpu_stopper);
+	unsigned int c;
+
+	pr_emerg("\n");
+	pr_emerg("=====================================================\n");
+	pr_emerg("STOPPER DEADLOCK: migration/%u stuck in\n"
+		 "multi_cpu_stop for ~%u ms\n"
+		 "Suspected cause: nested cpu_stop_queue_work() re-entrancy\n"
+		 "  e.g. active_load_balance_cpu_stop()\n"
+		 "       -> finish_task_switch() -> run_balance_callbacks()\n"
+		 "       -> sched_balance_rq() -> stop_one_cpu_nowait()\n"
+		 "  while already executing inside stop_two_cpus().\n",
+		 cpu, jiffies_to_msecs(elapsed_j));
+	pr_emerg("=====================================================\n");
+
+	/*
+	 * Section 1: OUTER stopper — the cpu_stop_work that initiated
+	 * stop_two_cpus() and triggered the nested re-entrancy.
+	 * This is the single most important field for root-cause analysis.
+	 */
+	pr_emerg("=== offending CPU%u outer stopper ===\n", cpu);
+	pr_emerg("  outer fn    : %pS\n", st->fn);
+	pr_emerg("  outer caller: %pS\n", (void *)st->caller);
+
+	/* Section 2: state machine position and ack count */
+	stopper_dump_msdata(msdata, cpu);
+
+	/*
+	 * Section 3: CPU masks.
+	 *   cpu_dying_mask == 0 -> load-balancer nested stop (our case)
+	 *   cpu_dying_mask != 0 -> hotplug-triggered variant
+	 */
+	pr_emerg("=== CPU masks ===\n");
+	pr_emerg("  cpu_online_mask : %*pbl\n",
+		 cpumask_pr_args(cpu_online_mask));
+	pr_emerg("  cpu_active_mask : %*pbl\n",
+		 cpumask_pr_args(cpu_active_mask));
+	pr_emerg("  cpu_dying_mask  : %*pbl  (non-zero = hotplug variant)\n",
+		 cpumask_pr_args(cpu_dying_mask));

+	/* Section 4: per-CPU stopper state for every online CPU */
+	pr_emerg("=== per-CPU stopper state (all online CPUs) ===\n");
+	for_each_online_cpu(c)
+		stopper_dump_one_cpu(c);

+	/* Section 5: call stack of the stuck migration/N thread */
+	pr_emerg("=== migration/%u call stack ===\n", cpu);
+	dump_stack();

+	/* Section 6: IPI backtrace — same path as msm_watchdog ping_other_cpus. */
+	pr_emerg("=== IPI backtrace for ALL CPUs ===\n");
+	trigger_all_cpu_backtrace();

+	/* Section 7: all task states — SysRq-T equivalent. */
+	pr_emerg("=== all task states (SysRq-T equivalent) ===\n");
+	show_state();

+	pr_emerg("=====================================================\n");
+	pr_emerg("Calling panic() to trigger ramdump/minidump.\n"
+		 "bark_time (~9-11s) > %us threshold => ramdump wins.\n",
+		 stopper_timeout_sec);
+	pr_emerg("=====================================================\n");
+}
+
+/* -----------------------------------------------------------------------
+ * TEST INFRASTRUCTURE — #ifdef CONFIG_DEBUG_FS
+ * Zero code/data overhead in production builds (CONFIG_DEBUG_FS=n).
+ * ----------------------------------------------------------------------- */
+#ifdef CONFIG_DEBUG_FS
+
+static struct dentry *stopper_debugfs_root;
+
+/**
+ * stopper_test_dump_write() — safe dump trigger, NO panic.
+ *
+ * echo 1 > /sys/kernel/debug/stop_machine/trigger_dump
+ *
+ * Builds a synthetic multi_stop_data ON THE STACK and passes it to all
+ * 7 diagnostic sections inline.  The device stays up after the call.
+ *
+ * NOTE: stopper_deadlock_dump() is NOT called directly here even though
+ * it IS reachable (same TU; 'static' limits only external linkage).
+ * Reason: stopper_deadlock_dump() ends with pr_emerg("Calling panic()...")
+ * which would print a misleading message in a safe no-panic test.
+ * The 7 sections are reproduced inline; only that final banner is omitted.
+ *
+ * Use this to verify: %pS symbol resolution, %*pbl cpumask format,
+ * IPI delivery via trigger_all_cpu_backtrace(), show_state() output.
+ */
+static ssize_t stopper_test_dump_write(struct file *file,
+				       const char __user *buf,
+				       size_t count, loff_t *ppos)
+{
+	/*
+	 * Synthetic multi_stop_data on the stack — PREPARE-state deadlock,
+	 * 2 threads, 1 stuck (thread_ack=1).  Passed by address so that
+	 * stopper_dump_msdata() never dereferences a NULL pointer.
+	 */
+	struct multi_stop_data fake = {
+		.fn          = NULL,
+		.data        = NULL,
+		.num_threads = 2,
+		.active_cpus = NULL,	/* falls back to cpu_online_mask */
+		.state       = MULTI_STOP_PREPARE,
+	};
+	/* fake elapsed = threshold + 5 ticks ("just timed out") */
+	unsigned long fake_elapsed_j = stopper_timeout_sec * HZ + 5;
+	unsigned int cpu = smp_processor_id();
+	unsigned int c;
+
+	atomic_set(&fake.thread_ack, 1);
+
+	pr_warn("stop_machine: [TEST trigger_dump] no panic — check dmesg\n");

+	/* Header */
+	pr_emerg("\n=====================================================\n");
+	pr_emerg("[TEST TRIGGER] Synthetic stopper deadlock dump\n");
+	pr_emerg("  Simulating: migration/%u stuck for ~%u ms\n",
+		 cpu, jiffies_to_msecs(fake_elapsed_j));
+	pr_emerg("  Real CPU masks/stopper state shown. msdata is synthetic.\n");
+	pr_emerg("=====================================================\n");

+	/* Section 1: real outer stopper of this CPU (idle during test) */
+	pr_emerg("=== offending CPU%u outer stopper (REAL) ===\n", cpu);
+	pr_emerg("  outer fn    : %pS\n", this_cpu_ptr(&cpu_stopper)->fn);
+	pr_emerg("  outer caller: %pS\n",
+		 (void *)this_cpu_ptr(&cpu_stopper)->caller);

+	/* Section 2: synthetic msdata (labelled clearly) */
+	pr_emerg("=== multi_stop_data (SYNTHETIC) ===\n");
+	pr_emerg("  state       : %d (%s)\n",
+		 MULTI_STOP_PREPARE,
+		 stopper_state_names[MULTI_STOP_PREPARE]);
+	pr_emerg("  num_threads : %u\n", fake.num_threads);
+	pr_emerg("  thread_ack  : %d  <- should be 1\n",
+		 atomic_read(&fake.thread_ack));
+	pr_emerg("  inner fn    : (null) [real case: migrate_swap_stop]\n");
+	pr_emerg("  active_cpus : %*pbl\n",
+		 cpumask_pr_args(cpu_online_mask));

+	/* Section 3: real CPU masks */
+	pr_emerg("=== CPU masks (REAL) ===\n");
+	pr_emerg("  cpu_online_mask : %*pbl\n",
+		 cpumask_pr_args(cpu_online_mask));
+	pr_emerg("  cpu_active_mask : %*pbl\n",
+		 cpumask_pr_args(cpu_active_mask));
+	pr_emerg("  cpu_dying_mask  : %*pbl  (0 = load-balancer variant)\n",
+		 cpumask_pr_args(cpu_dying_mask));

+	/* Section 4: real per-CPU stopper state */
+	pr_emerg("=== per-CPU stopper state (REAL) ===\n");
+	for_each_online_cpu(c)
+		stopper_dump_one_cpu(c);

+	/* Section 5: real call stack of this thread */
+	pr_emerg("=== call stack of trigger thread (REAL) ===\n");
+	dump_stack();

+	/* Section 6: real IPI backtrace */
+	pr_emerg("=== IPI backtrace for ALL CPUs (REAL) ===\n");
+	trigger_all_cpu_backtrace();

+	/* Section 7: real task states */
+	pr_emerg("=== all task states (REAL SysRq-T) ===\n");
+	show_state();

+	/* "Calling panic()..." banner intentionally omitted — no panic here. */
+	pr_emerg("=====================================================\n");
+	pr_emerg("[TEST TRIGGER COMPLETE] No panic was called.\n");
+	pr_emerg("If all 7 sections printed: dump code is working correctly.\n");
+	pr_emerg("=====================================================\n");
+
+	return count;
+}
+
+static const struct file_operations stopper_test_dump_fops = {
+	.write  = stopper_test_dump_write,
+	.llseek = no_llseek,
+};
+
+/**
+ * stopper_test_panic_fn() — stop_machine callback that blocks past threshold.
+ *
+ * mdelay() busy-waits (no reschedule) to hold this CPU in the stopper RUN
+ * context.  Other CPUs spin in the PREPARE barrier with IRQs on, allowing
+ * jiffies to tick until STOPPER_TIMEOUT_JIFFIES fires.
+ */
+static int stopper_test_panic_fn(void *data)
+{
+	unsigned int sleep_ms = (stopper_timeout_sec + 2) * 1000;
+
+	pr_warn("stop_machine: [TEST simulate_panic] blocking %u ms\n",
+		sleep_ms);
+	mdelay(sleep_ms);
+	return 0;
+}
+
+/**
+ * stopper_test_panic_write() — simulate real deadlock.  WILL crash device.
+ *
+ * echo 1 > /sys/kernel/debug/stop_machine/simulate_panic
+ *
+ * Invokes stop_machine() with stopper_test_panic_fn() which delays past
+ * STOPPER_TIMEOUT_JIFFIES.  The REAL production path fires:
+ *   stopper_deadlock_dump() -> panic() -> ramdump captured.
+ *
+ * Recommended sequence on ramdump-enabled device:
+ *   echo 1 > /sys/module/stop_machine/parameters/stopper_timeout_sec
+ *   echo 1 > /sys/kernel/debug/stop_machine/simulate_panic
+ *
+ * WARNING: WILL CRASH THE DEVICE.  Only use when connected to a serial
+ *          console and a ramdump / minidump capture host.
+ */
+static ssize_t stopper_test_panic_write(struct file *file,
+					const char __user *buf,
+					size_t count, loff_t *ppos)
+{
+	pr_warn("stop_machine: [TEST simulate_panic] CRASH IN ~%us\n",
+		stopper_timeout_sec + 2);
+	pr_warn("stop_machine: [TEST] threshold=%us  blocker=%us\n",
+		stopper_timeout_sec, stopper_timeout_sec + 2);
+
+	stop_machine(stopper_test_panic_fn, NULL, NULL);
+
+	/* Should never reach here — panic() fired inside stop_machine(). */
+	return count;
+}
+
+static const struct file_operations stopper_test_panic_fops = {
+	.write  = stopper_test_panic_write,
+	.llseek = no_llseek,
+};
+
+static int __init stopper_debugfs_init(void)
+{
+	stopper_debugfs_root = debugfs_create_dir("stop_machine", NULL);
+	if (IS_ERR_OR_NULL(stopper_debugfs_root)) {
+		pr_warn("stop_machine: failed to create debugfs dir\n");
+		return -ENOMEM;
+	}
+
+	debugfs_create_file("trigger_dump",   0200, stopper_debugfs_root,
+			    NULL, &stopper_test_dump_fops);
+	debugfs_create_file("simulate_panic", 0200, stopper_debugfs_root,
+			    NULL, &stopper_test_panic_fops);
+
+	pr_info("stop_machine: debugfs at /sys/kernel/debug/stop_machine/\n");
+	pr_info("  trigger_dump   (safe — no panic)\n");
+	pr_info("  simulate_panic (WILL CRASH — ramdump device only)\n");
+	pr_info("  threshold: %us  (stopper_timeout_sec= to override)\n",
+		stopper_timeout_sec);
+	return 0;
+}
+late_initcall(stopper_debugfs_init);
+
+#endif /* CONFIG_DEBUG_FS */
+/* ----------------------------------------------------------------------- */
+
 struct multi_stop_data {
 	cpu_stop_fn_t fn;
 	void *data;
@@ -200,12 +544,16 @@ static int multi_cpu_stop(void *data)
 {
 	struct multi_stop_data *msdata = data;
 	enum multi_stop_state newstate, curstate = MULTI_STOP_NONE;
-	int cpu = smp_processor_id(), err = 0;
+	/*
+	 * FIX: smp_processor_id() returns unsigned int.  Using 'int cpu' is a
+	 * pre-existing type mismatch against cpumask_test_cpu(unsigned int, ...)
+	 * and per_cpu_ptr(..., unsigned int).  Clang 19 warns at every call site.
+	 * 'err' stays int: msdata->fn() can legitimately return negative values.
+	 */
+	unsigned int cpu = smp_processor_id();
+	int err = 0, timed_out = 0;
 	const struct cpumask *cpumask;
 	unsigned long flags;
+	unsigned long start_jiffies;
 	bool is_active;
 
 	/*
@@ -223,6 +571,13 @@ static int multi_cpu_stop(void *data)
 		is_active = cpumask_test_cpu(cpu, cpumask);
 	}
 
+	/*
+	 * Snapshot jiffies before the spin loop.
+	 * jiffies advances via the timer tick interrupt — the same subsystem
+	 * that drives the Qualcomm msm_watchdog pet_timer kthread.
+	 * See STOPPER_TIMEOUT_JIFFIES comment above for full rationale.
