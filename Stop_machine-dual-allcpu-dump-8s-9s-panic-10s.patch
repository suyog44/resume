+/* =========================================================
+ * INSERT POINT A
+ *
+ * Placed BEFORE enum multi_stop_state and struct cpu_stopper.
+ *
+ * RULE: nothing below may reference:
+ *   - cpu_stopper         (the DEFINE_PER_CPU variable, ~line 180)
+ *   - struct cpu_stopper  (the type, ~line 180)
+ *   - struct multi_stop_data  (defined ~line 210)
+ *
+ * stopper_snapshot_self() takes fn+caller as void*/ulong parameters
+ * to avoid needing struct cpu_stopper at this point.
+ * ========================================================= */
+
+/*
+ * STOPPER_TIMEOUT_JIFFIES: jiffies from spin entry to deadlock detection.
+ *   Fires only in MULTI_STOP_PREPARE state (IRQs ON, jiffies advancing).
+ *   In MULTI_STOP_DISABLE_IRQ/RUN: IRQs off, jiffies frozen,
+ *   time_after() permanently false -- no false positive.
+ *   HZ=250 on Qualcomm GKI targets: 8*HZ = 2000 jiffies = 8000ms.
+ */
+#define STOPPER_TIMEOUT_JIFFIES     (8 * HZ)
+
+/*
+ * ktime windows -- all measured from t_detect (the ktime when the first
+ * CPU's time_after() fires, i.e. T=8s from deadlock start):
+ *
+ *   DUMP1_WINDOW_MS:
+ *     Deadline for all PREPARE CPUs to complete FIRST dump_stack() (Sec5).
+ *     PREPARE CPUs write their done flag before the owner starts running,
+ *     so they complete near-instantly. DISABLE_IRQ CPUs never set the
+ *     flag; owner logs "see ramdump" for them.
+ *     t_detect + 800ms = T=8.8s.
+ *
+ *   DUMP2_TRIGGER_MS:
+ *     When owner triggers SECOND dump on all non-owner CPUs.
+ *     Set equal to DUMP1_WINDOW_MS so the second dump starts immediately
+ *     after Sec5 completes. t_detect + 800ms = T=8.8s.
+ *
+ *   DUMP2_WINDOW_MS:
+ *     Deadline for all PREPARE CPUs to complete SECOND dump_stack().
+ *     Non-owners have DUMP2_WINDOW_MS - DUMP2_TRIGGER_MS = 800ms
+ *     after the trigger to finish. t_detect + 1600ms = T=9.6s.
+ *
+ *   PANIC_WINDOW_MS:
+ *     When panic() is called. t_detect + 2000ms = T=10s.
+ *     Qualcomm msm_watchdog bark_time ~11s -> 1s margin.
+ *
+ * Full timeline:
+ *   T=8.0s  time_after() fires: FIRST all-CPU dump_stack() [Phase 1]
+ *   T=8.8s  Sec5 deadline:      SECOND all-CPU dump_stack() [Phase 3]
+ *   T=9.6s  Sec7 deadline:      second dump collection complete
+ *   T=10.0s panic()             [Qualcomm bark: ~T=11s, 1s margin]
+ */
+#define STOPPER_DUMP1_WINDOW_MS     800ULL
+#define STOPPER_DUMP2_TRIGGER_MS    800ULL
+#define STOPPER_DUMP2_WINDOW_MS     1600ULL
+#define STOPPER_PANIC_WINDOW_MS     2000ULL
+
+static_assert(CONFIG_HZ >= 100,
+	"stop_machine deadlock detection requires CONFIG_HZ >= 100");
+
+/*
+ * stopper_dump_owner: -1 = no owner.
+ * First CPU winning atomic_cmpxchg(&stopper_dump_owner, -1, cpu) becomes
+ * the sole dump orchestrator.  All other detecting CPUs become "non-owners"
+ * and follow the second-dump protocol.
+ */
+static atomic_t stopper_dump_owner = ATOMIC_INIT(-1);
+
+/*
+ * stopper_first_dump_done: set to 1 by each PREPARE CPU after its FIRST
+ * dump_stack() completes (Phase 1c).  Zero-initialised at boot.
+ * Owner polls this per-CPU in Sec5 (stopper_wait_for_first_dumps).
+ */
+static DEFINE_PER_CPU(atomic_t, stopper_first_dump_done);
+
+/*
+ * stopper_second_dump_trigger: owner sets to 1 to signal all non-owner
+ * PREPARE CPUs that it is time to perform their SECOND dump_stack().
+ * Non-owners poll this in their post-Phase-1 spin loop.
+ * smp_wmb() before atomic_set() ensures Sec1-6 output is ordered before
+ * this signal is visible.
+ */
+static atomic_t stopper_second_dump_trigger = ATOMIC_INIT(0);
+
+/*
+ * stopper_second_dump_done: set to 1 by each CPU (owner and non-owners)
+ * after its SECOND dump_stack() completes.  Zero-initialised at boot.
+ * Owner polls this per-CPU in Sec7 (stopper_wait_for_second_dumps).
+ */
+static DEFINE_PER_CPU(atomic_t, stopper_second_dump_done);
+
+/**
+ * struct stopper_cpu_snapshot - per-CPU state captured at timeout
+ *
+ * Written into own percpu slot by each detecting CPU in Phase 1.
+ * Lockless: each CPU writes only its own slot.
+ * Read by dump owner in stopper_print_other_snapshots().
+ *
+ * smp_store_release(&snap->valid, true) on write (after all fields).
+ * smp_load_acquire(&snap->valid) on read (guards all field accesses).
+ */
+struct stopper_cpu_snapshot {
+	unsigned int  cpu;
+	int           curstate;
+	bool          is_active;
+	void         *fn;
+	unsigned long caller;
+	unsigned long elapsed_j;
+	bool          valid;
+};
+
+static DEFINE_PER_CPU(struct stopper_cpu_snapshot, stopper_snapshot);
+
+/**
+ * stopper_snapshot_self() - write this CPU's state into its percpu slot
+ * @cpu:        this CPU's index
+ * @curstate:   multi_stop_state at detection
+ * @is_active:  true if this CPU is the fn-executing CPU
+ * @fn:         stopper fn (read at call site; cpu_stopper in scope there)
+ * @caller:     stopper caller (same)
+ * @elapsed_j:  jiffies elapsed since spin entry
+ *
+ * Called by ALL detecting CPUs in Phase 1 before the cmpxchg.
+ * Writes only to this CPU's own percpu slot -- always lock-free.
+ * smp_store_release() ensures all payload fields are visible before
+ * snap->valid becomes true.
+ */
+static void stopper_snapshot_self(unsigned int cpu, int curstate,
+				  bool is_active, void *fn,
+				  unsigned long caller,
+				  unsigned long elapsed_j)
+{
+	struct stopper_cpu_snapshot *snap = this_cpu_ptr(&stopper_snapshot);
+
+	snap->cpu       = cpu;
+	snap->curstate  = curstate;
+	snap->is_active = is_active;
+	snap->fn        = fn;
+	snap->caller    = caller;
+	snap->elapsed_j = elapsed_j;
+	smp_store_release(&snap->valid, true);
+}
+
+/* === end INSERT POINT A === */
