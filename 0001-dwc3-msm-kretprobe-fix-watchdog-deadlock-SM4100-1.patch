 				   struct pt_regs *regs)
 {
@@ -165,9 +240,16 @@
 		 *
 		 * However, UVC (USB Video Class) requires real-time priority
 		 * to avoid frame drops and glitches. So we conditionally set
-		 * the scheduler policy based on whether UVC is in the composition:
-		 * - UVC present: Use SCHED_FIFO with highest priority
-		 * - UVC absent: Use SCHED_NORMAL to avoid RT throttling
+		 * the scheduler policy based on whether UVC is in the
+		 * composition:
+		 *   - UVC present: Use SCHED_FIFO with highest priority
+		 *   - UVC absent:  Use SCHED_NORMAL to avoid RT throttling
+		 *
+		 * IMPORTANT: sched_set_fifo/sched_set_normal are NOT called
+		 * directly here. Calling them from kretprobe context triggers
+		 * the WALT rq->lock -> stop_machine deadlock on SM4100/SM5100
+		 * (hardlockup NMI at 12s). All scheduler policy changes are
+		 * deferred to system_wq via dwc3_irq_sched_work.
 		 */
 		struct irq_desc *irq_desc = irq_to_desc(dwc->irq_gadget);
 		struct irqaction *action = irq_desc ? irq_desc->action : NULL;
@@ -175,31 +257,29 @@
 
 		dwc3_msm_notify_event(dwc, DWC3_GSI_EVT_BUF_SETUP, 0);
 
-		/* Check if UVC function is present in the composition */
 		uvc_active = is_uvc_function_active(dwc);
 
-		for ( ; action != NULL; action = action->next) {
+		for (; action != NULL; action = action->next) {
 			if (action->thread) {
-				if (uvc_active) {
-					/*
-					 * UVC needs real-time priority to avoid frame drops.
-					 * Use sched_set_fifo() which sets SCHED_FIFO.
-					 */
-					sched_set_fifo(action->thread);
-					dev_info(dwc->dev,
-						"Set IRQ thread:%s pid:%d to SCHED_FIFO low priority (UVC active)\n",
+				struct dwc3_irq_sched_work *iw =
+					kmalloc(sizeof(*iw), GFP_ATOMIC);
+				if (iw) {
+					iw->thread   = action->thread;
+					iw->use_fifo = uvc_active;
+					INIT_WORK(&iw->work,
+						  dwc3_irq_sched_work_fn);
+					schedule_work(&iw->work);
+					dev_dbg(dwc->dev,
+						"Deferred %s for IRQ thread "
+						"%s pid %d\n",
+						uvc_active ? "SCHED_FIFO"
+							   : "SCHED_NORMAL",
 						action->thread->comm,
 						action->thread->pid);
 				} else {
-					/*
-					 * Non-UVC composition: use SCHED_NORMAL to avoid
-					 * RT throttling issues.
-					 */
-					sched_set_normal(action->thread, MIN_NICE);
-					dev_info(dwc->dev,
-						"Set IRQ thread:%s pid:%d to SCHED_NORMAL (no UVC)\n",
-						action->thread->comm,
-						action->thread->pid);
+					dev_warn(dwc->dev,
+						 "kmalloc failed, IRQ thread "
+						 "priority not updated\n");
 				}
 				break;
 			}
@@ -213,6 +293,10 @@
 	return 0;
 }
 
