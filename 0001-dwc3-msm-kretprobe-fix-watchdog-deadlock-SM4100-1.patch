+/* ------------------------------------------------------------------ */
+/* Tracepoint callbacks - replaces 5x unsafe kretprobes               */
+/* ------------------------------------------------------------------ */
+
+/*
+ * The original code registered kretprobes on these 5 functions:
+ *   trace_event_raw_event_dwc3_log_request
+ *   trace_event_raw_event_dwc3_log_gadget_ep_cmd
+ *   trace_event_raw_event_dwc3_log_trb
+ *   trace_event_raw_event_dwc3_log_event
+ *   trace_event_raw_event_dwc3_log_ep
+ *
+ * This is unsafe for three reasons:
+ *
+ *   1. The kretprobe handlers called dbg_trace_* helpers which
+ *      re-triggered the same tracepoints -> recursive kprobe hit ->
+ *      BUG_ON(regs == NULL).
+ *
+ *   2. Each registration called stop_machine() to write a BRK opcode.
+ *      5 extra stop_machine() calls during module init on an already-
+ *      strained SM4100 cluster compounded the 10s kworker hang.
+ *
+ *   3. Argument extraction via regs->regs[1..4] is fragile across GKI
+ *      versions. If tracepoint calling convention changes, code silently
+ *      reads garbage with no compile-time check.
+ *
+ * register_trace_*() hooks the tracepoint call site via the tracepoint
+ * mechanism: no BRK injection, no stop_machine(), no re-entry risk,
+ * typed arguments checked at compile time.
+ */
+
+static void dwc3_tp_log_request_cb(void *d, struct dwc3_request *req)
+{
+	dbg_trace_ep_queue(req);
+}
+
+static void dwc3_tp_log_gadget_ep_cmd_cb(void *d, struct dwc3_ep *dep,
+	unsigned int cmd, struct dwc3_gadget_ep_cmd_params *param,
+	int cmd_status)
+{
+	dbg_trace_gadget_ep_cmd(dep, cmd, param, cmd_status);
+}
+
+static void dwc3_tp_log_trb_cb(void *d, struct dwc3_ep *dep,
+	struct dwc3_trb *trb)
+{
+	dbg_trace_trb_prepare(dep, trb);
+}
+
+static void dwc3_tp_log_event_cb(void *d, u32 event, struct dwc3 *dwc)
+{
+	dbg_trace_event(event, dwc);
+}
+
+static void dwc3_tp_log_ep_cb(void *d, struct dwc3_ep *dep)
+{
+	dbg_trace_ep(dep);
+}
+
+static int dwc3_tp_register_all(void)
+{
+	int ret;
 
-#define ENTRY_EXIT(name) {\
-	.handler = exit_##name,\
-	.entry_handler = entry_##name,\
-	.data_size = sizeof(union kprobe_data),\
-	.maxactive = 8,\
-	.kp.symbol_name = #name,\
+#define REG_TP(name, cb) \
+	ret = register_trace_##name(cb, NULL); \
+	if (ret) { \
+		pr_err("[dwc3_kretprobe] register_trace_" #name \
+		       " failed: %d\n", ret); \
+		return ret; \
+	}
+	REG_TP(dwc3_log_request,       dwc3_tp_log_request_cb)
+	REG_TP(dwc3_log_gadget_ep_cmd, dwc3_tp_log_gadget_ep_cmd_cb)
+	REG_TP(dwc3_log_trb,           dwc3_tp_log_trb_cb)
+	REG_TP(dwc3_log_event,         dwc3_tp_log_event_cb)
+	REG_TP(dwc3_log_ep,            dwc3_tp_log_ep_cb)
+#undef REG_TP
+	return 0;
 }
 
-#define ENTRY(name) {\
-	.entry_handler = entry_##name,\
-	.data_size = sizeof(union kprobe_data),\
-	.maxactive = 8,\
-	.kp.symbol_name = #name,\
+static void dwc3_tp_unregister_all(void)
+{
+	unregister_trace_dwc3_log_request(dwc3_tp_log_request_cb, NULL);
+	unregister_trace_dwc3_log_gadget_ep_cmd(
+			dwc3_tp_log_gadget_ep_cmd_cb, NULL);
+	unregister_trace_dwc3_log_trb(dwc3_tp_log_trb_cb, NULL);
+	unregister_trace_dwc3_log_event(dwc3_tp_log_event_cb, NULL);
+	unregister_trace_dwc3_log_ep(dwc3_tp_log_ep_cb, NULL);
+	tracepoint_synchronize_unregister();
+}
+
+/* ------------------------------------------------------------------ */
+/* kretprobe table                                                     */
+/* ------------------------------------------------------------------ */
+
+#define ENTRY_EXIT(name) {				\
+	.handler       = exit_##name,			\
+	.entry_handler = entry_##name,			\
+	.data_size     = sizeof(union kprobe_data),	\
+	.maxactive     = 8,				\
+	.kp.symbol_name = #name,			\
+}
+
+#define ENTRY(name) {					\
+	.entry_handler = entry_##name,			\
+	.data_size     = sizeof(union kprobe_data),	\
+	.maxactive     = 8,				\
+	.kp.symbol_name = #name,			\
 }
 
 static struct kretprobe dwc3_msm_probes[] = {
@@ -400,34 +523,198 @@
 	ENTRY_EXIT(dwc3_gadget_pullup),
 	ENTRY_EXIT(android_work),
 	ENTRY_EXIT(usb_ep_set_maxpacket_limit),
+	/*
+	 * maxactive overridden to num_possible_cpus()*2 at init time.
+	 * The hardcoded value of 8 causes missed probes on the 8-CPU
+	 * SM4100 cluster under burst USB events, silently leaving
+	 * dis_u2_susphy_quirk permanently false (USB PM regression).
+	 */
 	ENTRY_EXIT(dwc3_suspend_common),
-	ENTRY(trace_event_raw_event_dwc3_log_request),
-	ENTRY(trace_event_raw_event_dwc3_log_gadget_ep_cmd),
-	ENTRY(trace_event_raw_event_dwc3_log_trb),
-	ENTRY(trace_event_raw_event_dwc3_log_event),
-	ENTRY(trace_event_raw_event_dwc3_log_ep),
+	/*
+	 * trace_event_raw_event_dwc3_* INTENTIONALLY REMOVED.
+	 * Replaced by register_trace_*() callbacks in dwc3_tp_register_all().
+	 * See comment block above dwc3_tp_log_request_cb for full rationale.
+	 */
 };
 
+/* ------------------------------------------------------------------ */
+/* init / exit                                                         */
+/* ------------------------------------------------------------------ */
 
+/*
+ * dwc3_msm_kretprobe_init - arm all probes
+ *
+ * MUST only be called after dwc3_msm reaches MODULE_STATE_LIVE.
+ *
+ * Calling from module_init() while dwc3_msm symbols are still resolving
+ * causes the following chain on SM4100/SM5100:
+ *
+ *   register_kretprobe()
+ *     -> arm_kprobe()
+ *       -> aarch64_insn_patch_text()
+ *         -> stop_machine_cpuslocked()
+ *           -> stop_one_cpu() -> wait_for_completion()  [NO TIMEOUT]
+ *
+ * The kworker is blocked because resolve_symbol_wait() holds module_mutex
+ * and the stop_machine stopper thread cannot be scheduled (WALT init race
+ * on SM4100). Detected as hung kworker at 10s, hardlockup NMI at 12s.
+ *
+ * Fix: called only from MODULE_STATE_LIVE notifier below.
+ */
 int dwc3_msm_kretprobe_init(void)
 {
-	int ret;
-	int i;
+	int ret = 0;
+	int i, registered = 0;
 
-	for (i = 0; i < ARRAY_SIZE(dwc3_msm_probes) ; i++) {
+	/* Override maxactive for suspend probe */
+	for (i = 0; i < ARRAY_SIZE(dwc3_msm_probes); i++) {
