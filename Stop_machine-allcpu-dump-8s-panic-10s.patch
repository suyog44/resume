+	 * 'err' stays int: msdata->fn() may return negative error codes.
+	 */
+	unsigned int cpu = smp_processor_id();
+	int err = 0, timed_out = 0;
 	const struct cpumask *cpumask;
 	unsigned long flags;
+	unsigned long start_jiffies;
 	bool is_active;

@@ -232,6 +564,11 @@ static int multi_cpu_stop(void *data)
 	is_active = cpumask_test_cpu(cpu, cpumask);
 	}

+	/*
+	 * Snapshot start time before the spin loop.
+	 * Advances at HZ=250 in PREPARE state (IRQs ON, timer tick active).
+	 */
+	start_jiffies = jiffies;
+
 	/* Simple state machine */
 	do {
 		/* Chill out and ensure we re-read multi_stop_state. */
@@ -250,9 +587,70 @@ static int multi_cpu_stop(void *data)
 		} else if (curstate > MULTI_STOP_PREPARE) {
 			/*
 			 * At this stage all other CPUs we depend on must spin
-			 * in the same loop. Any reason for hard-lockup should
-			 * be detected and reported on their side.
+			 * in the same loop. Touch the NMI watchdog and
+			 * suppress RCU stall warnings while we spin.
