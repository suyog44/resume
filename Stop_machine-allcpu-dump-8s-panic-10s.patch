+/* =========================================================
+ * INSERT POINT A
+ *
+ * Placed BEFORE enum multi_stop_state and struct cpu_stopper (~line 167).
+ *
+ * RULE: nothing below may reference:
+ *   - cpu_stopper    (the DEFINE_PER_CPU variable, defined ~line 180)
+ *   - struct cpu_stopper  (the type, defined ~line 180)
+ *   - struct multi_stop_data  (defined ~line 210)
+ *
+ * stopper_snapshot_self() takes fn+caller as void*/ulong parameters
+ * specifically to avoid needing struct cpu_stopper here.
+ * ========================================================= */
+
+/*
+ * Detection threshold: 8 seconds from spin entry.
+ * HZ=250 on target -> 2000 jiffies = 8000ms.
+ * Fires only in PREPARE state (IRQs ON, jiffies advancing).
+ * In DISABLE_IRQ/RUN: IRQs off, jiffies frozen, time_after() false.
+ */
+#define STOPPER_TIMEOUT_JIFFIES   (8 * HZ)
+
+/*
+ * All-CPU dump collection window: 2s from detection = T=10s from deadlock.
+ * Owner polls stopper_dump_done for each online CPU during this window.
+ * PREPARE CPUs complete near-instantly (they dump in Phase 1 at T=8s).
+ * DISABLE_IRQ CPUs time out (jiffies frozen, they cannot detect).
+ * Uses ktime_get() -- reads ARM hardware counter directly, IRQ-independent.
+ */
+#define STOPPER_DUMP_WINDOW_MS    2000ULL

+static_assert(HZ > 0, "HZ must be > 0");
+
+/*
+ * stopper_dump_owner: -1 = no owner.
+ * First CPU winning atomic_cmpxchg becomes sole dump owner.
+ * All other detecting CPUs spin after writing their snapshot.
+ */
+static atomic_t stopper_dump_owner = ATOMIC_INIT(-1);
+
+/*
+ * stopper_dump_done: set to 1 by each CPU after it completes dump_stack().
+ * Zero-initialised at boot (DEFINE_PER_CPU default).
+ * Written by the owning CPU only, read by the dump owner.
+ */
+DEFINE_PER_CPU(atomic_t, stopper_dump_done);
+
+/**
+ * struct stopper_cpu_snapshot - state captured by each CPU at timeout
+ *
+ * Written into own percpu slot (lockless, no contention).
+ * Read by dump owner in stopper_print_other_snapshots().
+ *
+ * smp_store_release(&snap->valid, true) on write (after all fields).
+ * smp_load_acquire(&snap->valid) on read (before accessing fields).
+ *
+ * @fn and @caller are passed as parameters (not read from cpu_stopper
+ * here) because struct cpu_stopper is not yet defined at INSERT POINT A.
+ */
+struct stopper_cpu_snapshot {
+	unsigned int  cpu;
+	int           curstate;
+	bool          is_active;
+	void         *fn;
+	unsigned long caller;
+	unsigned long elapsed_j;
+	bool          valid;
+};
+
+DEFINE_PER_CPU(struct stopper_cpu_snapshot, stopper_snapshot);
+
+/**
+ * stopper_snapshot_self() - write this CPU's state into its percpu slot
+ * @cpu:        this CPU's id
+ * @curstate:   multi_stop_state at detection
+ * @is_active:  true if this is the fn-running CPU
+ * @fn:         stopper fn -- read at call site (cpu_stopper in scope there)
+ * @caller:     stopper caller -- same, read at call site
+ * @elapsed_j:  jiffies elapsed since spin entry
+ *
+ * Called by ALL detecting CPUs in Phase 1, before the cmpxchg.
+ * Writes only to this CPU's own percpu slot -- always lockless.
+ * smp_store_release() ensures payload visible before valid=true.
+ */
+static void stopper_snapshot_self(unsigned int cpu, int curstate,
+				  bool is_active, void *fn,
+				  unsigned long caller,
+				  unsigned long elapsed_j)
+{
+	struct stopper_cpu_snapshot *snap = this_cpu_ptr(&stopper_snapshot);
+
+	snap->cpu       = cpu;
+	snap->curstate  = curstate;
+	snap->is_active = is_active;
+	snap->fn        = fn;
+	snap->caller    = caller;
+	snap->elapsed_j = elapsed_j;
+	smp_store_release(&snap->valid, true);
+}
+
+/* === end INSERT POINT A === */
+
 /*
  * Structure to determine completion condition and record errors. May
  * be shared by works on different cpus.
@@ -195,6 +309,218 @@ struct multi_stop_data {
 	atomic_t thread_ack;
 };

+/* =========================================================
+ * INSERT POINT B -- after struct multi_stop_data.
+ *
+ * [FIX-A] All helpers referencing cpu_stopper, struct cpu_stopper, or
+ * struct multi_stop_data are placed HERE where all three are defined.
+ * ========================================================= */
+
+static const char * const stopper_state_names[] = {
+	[MULTI_STOP_NONE]        = "NONE",
+	[MULTI_STOP_PREPARE]     = "PREPARE",
+	[MULTI_STOP_DISABLE_IRQ] = "DISABLE_IRQ",
+	[MULTI_STOP_RUN]         = "RUN",
+	[MULTI_STOP_EXIT]        = "EXIT",
+};
+static_assert(ARRAY_SIZE(stopper_state_names) == MULTI_STOP_EXIT + 1,
+	"stopper_state_names[] out of sync with enum multi_stop_state");
+
+static inline const char *stopper_state_name(int s)
+{
+	return ((unsigned int)s < ARRAY_SIZE(stopper_state_names) &&
+		stopper_state_names[s])
+		? stopper_state_names[s] : "UNKNOWN";
+}
+
+/**
+ * stopper_dump_one_cpu() - print one CPU's stopper state to dmesg
+ * @cpu: target CPU (dump owner only -- called for owner CPU in Sec4)
+ */
+static noinline void stopper_dump_one_cpu(unsigned int cpu)
+{
+	struct cpu_stopper *st = per_cpu_ptr(&cpu_stopper, cpu);
+	struct cpu_stop_work *w;
+	int n = 0;
+
+	pr_emerg("  task=%-16s enabled=%d\n",
+		 st->thread ? st->thread->comm : "(null)",
+		 st->enabled);
+	pr_emerg("  fn=%pS  caller=%pS\n",
+		 st->fn, (void *)st->caller);
+	list_for_each_entry(w, &st->works, list) {
+		pr_emerg("  pending[%d]: fn=%pS caller=%pS\n",
+			 n++, w->fn, (void *)w->caller);
+		if (n >= 8) {
+			pr_emerg("  ... (truncated at 8)\n");
+			break;
+		}
+	}
+	if (!n)
+		pr_emerg("  pending works: (none)\n");
+}
+
+/**
+ * stopper_dump_msdata() - print multi_stop_data fields to dmesg
+ */
+static noinline void stopper_dump_msdata(struct multi_stop_data *msdata,
+					 unsigned int owner_cpu)
+{
+	int state = READ_ONCE(msdata->state);
+
+	pr_emerg("=== Sec2: multi_stop_data (owner CPU%u) ===\n", owner_cpu);
+	pr_emerg("  state       : %d (%s)\n", state, stopper_state_name(state));
+	pr_emerg("  num_threads : %u\n", msdata->num_threads);
+	pr_emerg("  thread_ack  : %d  <- CPUs NOT yet acked\n",
+		 atomic_read(&msdata->thread_ack));
+	pr_emerg("  inner fn    : %pS\n", msdata->fn);
+	pr_emerg("  active_cpus : %*pbl\n",
+		 cpumask_pr_args(msdata->active_cpus
+			? msdata->active_cpus : cpu_online_mask));
+}
+
+/**
+ * stopper_wait_for_cpu_dumps() - poll all CPUs' dump_done flags
+ * @owner_cpu:     dump owner -- already done, skip in wait loop
+ * @t_dump_limit:  ktime deadline (T=8s from deadlock start)
+ *
+ * Waits for each online CPU to set its stopper_dump_done atomic after
+ * completing dump_stack() in Phase 1.
+ *
+ * PREPARE CPUs: detected timeout, dumped in Phase 1, done immediately.
+ * DISABLE_IRQ CPUs: jiffies frozen, never detected, never set done.
+ *   -> owner waits until t_dump_limit then logs a timeout message.
+ *   -> their stacks are captured in the panic() ramdump.
+ *
+ * ktime_get() reads the ARM hardware monotonic counter directly.
+ * It does NOT depend on jiffies or the timer IRQ -- correct for use
+ * here where some CPUs have local IRQs disabled.
+ */
+static noinline void stopper_wait_for_cpu_dumps(unsigned int owner_cpu,
+						ktime_t t_dump_limit)
+{
+	unsigned int c;
+
+	pr_emerg("=== Sec5: waiting for all CPUs to complete dump_stack"
+		 " (deadline T=10s) ===\n");

+	for_each_online_cpu(c) {
+		if (c == owner_cpu)
+			continue;
+
+		while (!atomic_read(per_cpu_ptr(&stopper_dump_done, c))) {
+			if (ktime_after(ktime_get(), t_dump_limit)) {
+				pr_emerg("  [CPU%u] dump timeout: IRQs"
+					 " likely disabled (DISABLE_IRQ/"
+					 "RUN state) -- stack in ramdump\n",
+					 c);
+				goto next_cpu;
+			}
+			cpu_relax();
+		}
+		pr_emerg("  [CPU%u] dump_stack complete\n", c);
+next_cpu:;
+	}
+}
+
+/**
+ * stopper_print_other_snapshots() - print percpu snapshots from all CPUs
+ * @owner_cpu: skip owner (its snapshot is in Sec1/Sec4)
+ *
+ * Reads stopper_snapshot percpu slots written by Phase 1 writers.
+ * smp_load_acquire() pairs with smp_store_release() in stopper_snapshot_self().
+ */
+static noinline void stopper_print_other_snapshots(unsigned int owner_cpu)
+{
+	unsigned int c;
+
+	pr_emerg("=== Sec6: per-CPU snapshots at timeout detection ===\n");
+	pr_emerg("  Signature A: one is_active=YES  -> LB re-entrancy\n");
+	pr_emerg("  Signature B: ALL is_active=YES  -> concurrent exhaustion\n");

+	for_each_online_cpu(c) {
+		struct stopper_cpu_snapshot *snap;
+		int state;
+
+		if (c == owner_cpu)
+			continue;
+
+		snap = per_cpu_ptr(&stopper_snapshot, c);
+		if (!smp_load_acquire(&snap->valid)) {
+			pr_emerg("  [CPU%u] no snapshot (DISABLE_IRQ/"
+				 "RUN -- could not detect timeout)\n", c);
+			continue;
+		}
+
+		state = snap->curstate;
+		pr_emerg("  [CPU%u] state=%-11s is_active=%-5s"
+			 " elapsed=~%ums\n",
+			 c, stopper_state_name(state),
+			 snap->is_active ? "YES" : "no",
+			 jiffies_to_msecs(snap->elapsed_j));
+		pr_emerg("         fn=%pS\n", snap->fn);
+		pr_emerg("         caller=%pS\n", (void *)snap->caller);
+	}
+}
+
+/**
+ * stopper_deadlock_dump() - full diagnostic dump then spin to T=10s panic
+ * @cpu:       dump owner (the detecting CPU)
+ * @msdata:    shared multi_stop_data
+ * @elapsed_j: jiffies elapsed since spin entry
+ *
+ * Sections:
+ *   Sec1: outer stopper fn+caller (root cause)
+ *   Sec2: multi_stop_data state
+ *   Sec3: CPU masks
+ *   Sec4: owner CPU stopper state (detailed)
+ *   Sec5: wait for all CPUs' Phase-1 dump_stack() to complete (-> T=8s)
+ *   Sec6: print all percpu snapshots
+ *   Then spin until T=10s, then return for panic().
+ *
+ * noinline: keeps migration/N visible at top of ramdump call stack.
+ */
+static noinline void stopper_deadlock_dump(unsigned int cpu,
+					   struct multi_stop_data *msdata,
+					   unsigned long elapsed_j,
+					   ktime_t t_detect)
+{
+	struct cpu_stopper *st = this_cpu_ptr(&cpu_stopper);
+	ktime_t t_dump_limit = ktime_add_ms(t_detect, STOPPER_DUMP_WINDOW_MS);
+
+	pr_emerg("\n");
+	pr_emerg("=====================================================\n");
+	pr_emerg("STOPPER DEADLOCK: migration/%u stuck ~%u ms\n"
+		 "Dump owner: CPU%u  |  All-CPU dumps: Sec5 (T=8-10s)\n"
+		 "Panic at: T=10s  |  WDT bark: ~T=11s\n"
+		 "Patterns: A=LB re-entrancy  B=concurrent exhaustion\n",
+		 cpu, jiffies_to_msecs(elapsed_j), cpu);
+	pr_emerg("=====================================================\n");
+
+	/* Sec1: root cause -- which callback triggered the deadlock */
+	pr_emerg("=== Sec1: CPU%u outer stopper (root cause) ===\n", cpu);
+	pr_emerg("  outer fn    : %pS\n", st->fn);
+	pr_emerg("  outer caller: %pS\n", (void *)st->caller);
+
+	/* Sec2: state machine snapshot */
+	stopper_dump_msdata(msdata, cpu);
+
+	/* Sec3: CPU masks -- cpu_dying_mask=0 -> LB variant, not hotplug */
+	pr_emerg("=== Sec3: CPU masks ===\n");
+	pr_emerg("  cpu_online_mask : %*pbl\n",
+		 cpumask_pr_args(cpu_online_mask));
+	pr_emerg("  cpu_active_mask : %*pbl\n",
+		 cpumask_pr_args(cpu_active_mask));
+	pr_emerg("  cpu_dying_mask  : %*pbl  (non-zero = hotplug variant)\n",
+		 cpumask_pr_args(cpu_dying_mask));
+
+	/* Sec4: detailed stopper state of the dump-owner CPU only */
+	pr_emerg("=== Sec4: CPU%u stopper state (detailed) ===\n", cpu);
+	stopper_dump_one_cpu(cpu);
+
+	/*
+	 * Sec5: block until every online CPU has completed its Phase-1
+	 * dump_stack(), or until the T=8s ktime deadline.
+	 * PREPARE CPUs: already done (they dumped in Phase 1 before cmpxchg).
+	 * DISABLE_IRQ CPUs: could not detect timeout, will time out here,
+	 *   their stacks are captured in the panic() ramdump.
+	 */
+	stopper_wait_for_cpu_dumps(cpu, t_dump_limit);
+
+	/* Sec6: lightweight snapshots showing state at detection moment */
+	stopper_print_other_snapshots(cpu);
+
+	pr_emerg("=====================================================\n");
+	pr_emerg("All dumps complete. Calling panic() now.\n");
+	pr_emerg("DISABLE_IRQ CPU stacks available in ramdump.\n");
+	pr_emerg("=====================================================\n");
+}
+
+/* === end INSERT POINT B === */
