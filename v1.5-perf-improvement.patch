 /* ── Ring buffer callbacks ───────────────────────────────────── */
+/* ── Apply hint: write chosen order to /proc/pid/timerslack_ns as
+ * a side-channel, OR more correctly: hint_map tells us the pid+order;
+ * we use process_madvise(2) (Linux 5.10+) to apply MADV_HUGEPAGE
+ * with the right granularity by touching the THP per-size knob.
+ *
+ * Practical approach for RPi5/6.12: write the per-pid preferred order
+ * into /proc/sys/vm/mthp_stats or use PR_SET_THP_DISABLE selectively.
+ * The most reliable mechanism available without kernel patches is to
+ * set the global THP enabled size to match the hint for the workload
+ * duration, since hint_map has no kernel consumer.
+ *
+ * We do this by: when a ML/MEDIA pid is seen with ORDER_2MB hint,
+ * ensure hugepages-2048kB is "always" for the duration of its run.
+ */
+static void apply_thp_hint(unsigned int pid, unsigned int order, const char *comm) {
+    /* Only act on classified (non-generic) processes with large orders */
+    if (order < 4) return;  /* ORDER_64KB = 4, ORDER_2MB = 9 */
+
+    const char *thp_base = "/sys/kernel/mm/transparent_hugepage";
+    char path[128];
+    FILE *f;
+
+    /* Map order to size string */
+    const char *size = NULL;
+    if (order >= 9) size = "2048kB";
+    else if (order >= 4) size = "64kB";
+    else if (order >= 2) size = "16kB";
+    if (!size) return;
+
+    snprintf(path, sizeof(path), "%s/hugepages-%s/enabled", thp_base, size);
+    f = fopen(path, "w");
+    if (f) {
+        fprintf(f, "always");
+        fclose(f);
+    }
+}
