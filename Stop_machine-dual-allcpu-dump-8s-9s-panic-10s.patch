+/**
+ * stopper_dump_one_cpu() - print one CPU's stopper state to dmesg
+ * @cpu: target CPU
+ */
+static noinline void stopper_dump_one_cpu(unsigned int cpu)
+{
+	struct cpu_stopper *st = per_cpu_ptr(&cpu_stopper, cpu);
+	struct cpu_stop_work *w;
+	int n = 0;
+
+	pr_emerg("  task=%-16s enabled=%d\n",
+		 st->thread ? st->thread->comm : "(null)", st->enabled);
+	pr_emerg("  fn=%pS  caller=%pS\n",
+		 READ_ONCE(st->fn), (void *)READ_ONCE((unsigned long)st->caller));
+	list_for_each_entry(w, &st->works, list) {
+		pr_emerg("  pending[%d]: fn=%pS caller=%pS\n",
+			 n++, w->fn, (void *)w->caller);
+		if (n >= 8) {
+			pr_emerg("  ... (truncated at 8)\n");
+			break;
+		}
+	}
+	if (!n)
+		pr_emerg("  pending works: (none)\n");
+}
+
+/**
+ * stopper_dump_msdata() - print multi_stop_data fields to dmesg
+ */
+static noinline void stopper_dump_msdata(struct multi_stop_data *msdata,
+					 unsigned int owner_cpu)
+{
+	int state = READ_ONCE(msdata->state);
+
+	pr_emerg("=== Sec2: multi_stop_data (owner CPU%u) ===\n", owner_cpu);
+	pr_emerg("  state       : %d (%s)\n", state, stopper_state_name(state));
+	pr_emerg("  num_threads : %u\n", msdata->num_threads);
+	pr_emerg("  thread_ack  : %d  (CPUs not yet acked)\n",
+		 atomic_read(&msdata->thread_ack));
+	pr_emerg("  inner fn    : %pS\n", msdata->fn);
+	pr_emerg("  active_cpus : %*pbl\n",
+		 cpumask_pr_args(msdata->active_cpus
+			? msdata->active_cpus : cpu_online_mask));
+}
+
+/**
+ * stopper_wait_for_first_dumps() - poll all CPUs' first-dump-done flags
+ * @owner_cpu:    dump owner -- skip self in wait loop
+ * @t_limit:      ktime deadline (t_detect + DUMP1_WINDOW_MS)
+ *
+ * Waits for each online CPU to set stopper_first_dump_done after its
+ * FIRST dump_stack() in Phase 1.
+ *
+ * PREPARE CPUs:    detected timeout, dumped in Phase 1, done immediately.
+ * DISABLE_IRQ CPUs: jiffies frozen, never detected, never set the flag.
+ *   -> owner waits until t_limit then logs a timeout message.
+ *   -> their stacks are captured in the panic() ramdump.
+ *
+ * ktime_get() reads the ARM hardware monotonic counter -- does NOT depend
+ * on jiffies or the timer IRQ.  Safe when remote CPUs have IRQs disabled.
+ */
+static noinline void stopper_wait_for_first_dumps(unsigned int owner_cpu,
+						  ktime_t t_limit)
+{
+	unsigned int c;
+
+	pr_emerg("=== Sec5: waiting for FIRST dump_stack from all CPUs ===\n");
+	for_each_online_cpu(c) {
+		if (c == owner_cpu)
+			continue;
+		while (!atomic_read(per_cpu_ptr(&stopper_first_dump_done, c))) {
+			if (ktime_after(ktime_get(), t_limit)) {
+				pr_emerg("  [CPU%u] FIRST dump timeout:"
+					 " IRQs disabled (DISABLE_IRQ/RUN)"
+					 " -- stack in ramdump\n", c);
+				goto first_next_cpu;
+			}
+			cpu_relax();
+		}
+		pr_emerg("  [CPU%u] FIRST dump_stack complete\n", c);
+first_next_cpu:;
+	}
+}
+
+/**
+ * stopper_wait_for_second_dumps() - poll all CPUs' second-dump-done flags
+ * @owner_cpu:  dump owner -- skip self in wait loop
+ * @t_limit:    ktime deadline (t_detect + DUMP2_WINDOW_MS)
+ *
+ * Waits for each online CPU to set stopper_second_dump_done after its
+ * SECOND dump_stack().  Owner already set its own flag before calling here.
+ *
+ * Non-owner PREPARE CPUs: triggered by stopper_second_dump_trigger, they
+ *   dump and set done within ~800ms.
+ * DISABLE_IRQ CPUs: cannot poll the trigger, never set the flag.
+ *   -> owner waits until t_limit then logs a timeout message.
+ */
+static noinline void stopper_wait_for_second_dumps(unsigned int owner_cpu,
+						   ktime_t t_limit)
+{
+	unsigned int c;
+
+	pr_emerg("=== Sec7: waiting for SECOND dump_stack from all CPUs ===\n");
+	for_each_online_cpu(c) {
+		if (c == owner_cpu)
+			continue;
+		while (!atomic_read(per_cpu_ptr(&stopper_second_dump_done, c))) {
+			if (ktime_after(ktime_get(), t_limit)) {
+				pr_emerg("  [CPU%u] SECOND dump timeout:"
+					 " IRQs disabled (DISABLE_IRQ/RUN)"
+					 " -- stack in ramdump\n", c);
+				goto second_next_cpu;
+			}
+			cpu_relax();
+		}
+		pr_emerg("  [CPU%u] SECOND dump_stack complete\n", c);
+second_next_cpu:;
+	}
+}
+
+/**
+ * stopper_print_other_snapshots() - print percpu snapshots from all CPUs
+ * @owner_cpu: skip (its snapshot is inline in Sec1/Sec4)
+ *
+ * Reads stopper_snapshot percpu slots written by Phase 1 writers.
+ * smp_load_acquire() pairs with smp_store_release() in stopper_snapshot_self().
+ */
+static noinline void stopper_print_other_snapshots(unsigned int owner_cpu)
+{
+	unsigned int c;
+
+	pr_emerg("=== Sec6: per-CPU snapshots at detection (T=8s) ===\n");
+	pr_emerg("  Signature A: one  is_active=YES -> LB re-entrancy\n");
+	pr_emerg("  Signature B: ALL  is_active=YES -> concurrent exhaustion\n");
+	pr_emerg("  Signature G: CPU  is_active=NO, curstate=NONE"
+		 " -> WALT/kworker preempted mid-queue\n");
+
+	for_each_online_cpu(c) {
+		struct stopper_cpu_snapshot *snap =
+			per_cpu_ptr(&stopper_snapshot, c);
+		int state;
+
+		if (c == owner_cpu)
+			continue;
+		if (!smp_load_acquire(&snap->valid)) {
+			pr_emerg("  [CPU%u] no snapshot (DISABLE_IRQ/RUN --"
+				 " could not detect timeout)\n", c);
+			continue;
+		}
+		state = snap->curstate;
+		pr_emerg("  [CPU%u] state=%-11s is_active=%-5s elapsed=~%ums\n",
+			 c, stopper_state_name(state),
+			 snap->is_active ? "YES" : "no",
+			 jiffies_to_msecs(snap->elapsed_j));
+		pr_emerg("         fn=%pS\n", snap->fn);
+		pr_emerg("         caller=%pS\n", (void *)snap->caller);
+	}
+}
